#!/bin/sh
set -e

# Build and push the Fedify sidecar image for any destination that uses it.
case "$KAMAL_DESTINATION" in
  fedify|pessi|newfuture)
    echo "==> Building Fedify sidecar image (pessiv/metazine-fedify)..."
    docker buildx build --platform linux/amd64 --push -t pessiv/metazine-fedify ./fedify
    echo "==> Fedify sidecar image pushed"
    ;;
esac
