#!/bin/sh
set -e

# Reboot the Fedify sidecar after each deploy so the freshly-pushed image
# is picked up. Runs for any destination that has the accessory configured.
case "$KAMAL_DESTINATION" in
  fedify)
    echo "==> Rebooting Fedify accessory (fedify)..."
    kamal accessory reboot fedify -d fedify
    echo "==> Done"
    ;;
  pessi)
    echo "==> Rebooting Fedify accessory (pessi)..."
    kamal accessory reboot fedify -d pessi
    echo "==> Done"
    ;;
  newfuture)
    echo "==> Rebooting Fedify accessory (newfuture)..."
    kamal accessory reboot fedify -d newfuture
    echo "==> Done"
    ;;
esac
